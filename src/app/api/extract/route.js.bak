import { NextResponse } from 'next/server';
import { chromium } from 'playwright';

export async function POST(request) {
  let browser;
  try {
    const { locations, keywords } = await request.json();

    if (!locations || !locations.length || !keywords || !keywords.length) {
      return NextResponse.json({ error: 'Missing locations or keywords' }, { status: 400 });
    }

    console.log('🚀 Starting Robust Scraper for:', { locations, keywords });

    browser = await chromium.launch({ 
      headless: true,
      args: [
        '--disable-blink-features=AutomationControlled',
        '--lang=en-US,en',
        '--no-sandbox',
        '--disable-setuid-sandbox'
      ] 
    });
    
    const context = await browser.newContext({
      viewport: { width: 1280, height: 1000 },
      userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36',
      locale: 'en-US'
    });

    const allLeads = [];

    for (const location of locations) {
      for (const keyword of keywords) {
        const query = `${keyword} in ${location}`;
        const page = await context.newPage();
        
        try {
          // Force English locale with ?hl=en
          const searchUrl = `https://www.google.com/maps/search/${encodeURIComponent(query)}?hl=en`;
          await page.goto(searchUrl, { waitUntil: 'networkidle' });
          
          // Handle cookie consent (more aggressive)
          try {
            const consentSelectors = [
              'button[aria-label="Accept all"]',
              'button[aria-label="Agree"]',
              'form[action*="consent"] button',
              'button:has-text("Accept all")',
              'button:has-text("Agree")'
            ];
            
            for (const selector of consentSelectors) {
              const btn = page.locator(selector).first();
              if (await btn.isVisible({ timeout: 2000 })) {
                await btn.click();
                await page.waitForTimeout(1000);
                break;
              }
            }
          } catch (e) {}

          // Wait for results. Google Maps uses various selectors for the results list.
          const feedSelectors = ['div[role="feed"]', 'div[role="main"]', '.m67qzR'];
          let foundFeed = false;
          for (const selector of feedSelectors) {
            try {
              await page.waitForSelector(selector, { timeout: 8000 });
              foundFeed = true;
              break;
            } catch (e) {}
          }

          if (!foundFeed) {
            console.log(`Feed not found for ${query}. Checking if results exist...`);
          }

          // Scroll more aggressively
          for (let i = 0; i < 5; i++) {
            await page.mouse.wheel(0, 2000);
            await page.waitForTimeout(1500);
          }

          const results = await page.evaluate((kw, loc) => {
            const items = Array.from(document.querySelectorAll('div.Nv2PK, div.UaMeBe, div.VkpYff'));
            return items.map(item => {
              const name = item.querySelector('div.fontHeadlineSmall, .NrDZNb, .qBF1Pd')?.innerText || '';
              const link = item.querySelector('a.hfpxzc, a.V097gc')?.href || '';
              const ratingText = item.querySelector('span.MW4etd, .fontBodyMedium span[aria-hidden="true"]')?.innerText || '';
              const reviewsText = item.querySelector('span.UY7F9, .fontBodyMedium span[aria-label*="reviews"]')?.innerText || '';
              
              const rating = parseFloat(ratingText) || 0;
              const reviews = parseInt(reviewsText.replace(/[^0-9]/g, '')) || 0;
              
              const fullText = item.innerText;
              const lines = fullText.split('\n');
              let category = '';
              let address = '';
              let phone = item.querySelector('span.UsdlK, .W4P9ed')?.innerText || '';

              // Basic parsing from fullText if structured selectors fail
              if (lines.length > 2) {
                const infoLine = lines[1] || lines[2];
                if (infoLine.includes('·')) {
                  const parts = infoLine.split('·');
                  category = parts[0].trim();
                  address = parts[parts.length - 1].trim();
                } else {
                  category = infoLine.trim();
                }
              }

              // Filter out phone-like strings from address if they ended up there
              if (address.match(/\d{3,}/) && !phone) {
                phone = address;
                address = '';
              }

              const website = item.querySelector('a.lS30S')?.href || '';

              return {
                id: Math.random().toString(36).substr(2, 9),
                name: name.trim(),
                industry: category || kw,
                phone: phone.trim(),
                address: address.trim(),
                rating,
                reviewsCount: reviews,
                website,
                googleMapsLink: link,
                searchKeyword: kw,
                searchLocation: loc
              };
            }).filter(item => item.name); // Ensure name exists
          }, keyword, location);

          console.log(`Found ${results.length} leads for ${query}`);
          allLeads.push(...results);
        } catch (err) {
          console.error(`Error scraping ${query}:`, err);
        } finally {
          await page.close();
        }
      }
    }

    // De-duplicate leads by Maps Link or Name+Address
    const uniqueLeadsMap = new Map();
    allLeads.forEach(lead => {
      const key = lead.googleMapsLink || `${lead.name}-${lead.address}`;
      if (!uniqueLeadsMap.has(key)) {
        uniqueLeadsMap.set(key, lead);
      }
    });

    return NextResponse.json({ leads: Array.from(uniqueLeadsMap.values()) });

  } catch (error) {
    console.error('Extraction Error:', error);
    return NextResponse.json({ error: error.message }, { status: 500 });
  } finally {
    if (browser) await browser.close();
  }
}
